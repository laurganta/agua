# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
/agua-unity/[Ll]ibrary/
/agua-unity/[Tt]emp/
/agua-unity/[Oo]bj/
/agua-unity/[Bb]uild/
/agua-unity/[Bb]uilds/
/agua-unity/[Ll]ogs/
/agua-unity/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/agua-unity/[Mm]emoryCaptures/

# Recordings can get excessive in size
/agua-unity/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /agua-unity/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/agua-unity/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
/agua-unity.vs/

# Gradle cache directory
/agua-unity.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/agua-unity/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/agua-unity/[Aa]ssets/[Ss]treamingAssets/aa.meta
/agua-unity/[Aa]ssets/[Ss]treamingAssets/aa/*

# Never ignore DLLs in the FMOD subfolder.
!/agua-unity/[Aa]ssets/Plugins/FMOD/**/lib/*

# Don't ignore images and gizmos used by FMOD in the Unity Editor.
!/agua-unity/[Aa]ssets/Gizmos/FMOD/*
!/agua-unity/[Aa]ssets/Editor Default Resources/FMOD/*

# Ignore the Cache folder since it is updated locally.
/agua-unity/[Aa]ssets/Plugins/FMOD/Cache/*

# Ignore bank files in the StreamingAssets folder.
/agua-unity/[Aa]ssets/StreamingAssets/**/*.bank
/agua-unity/[Aa]ssets/StreamingAssets/**/*.bank.meta

# If the source bank files are kept outside of the StreamingAssets folder then these can be ignored.
# Log files can be ignored.
/agua-unity/fmod_editor.log


/agua-fmod/agua/.cache